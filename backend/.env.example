# ============================================
# SVCK Digital - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# Application Environment
ENVIRONMENT=development

# JWT Authentication (generate a strong random string, min 32 chars)
JWT_SECRET=your-strong-random-secret-here
JWT_ISSUER=svck-digital
JWT_EXPIRE_MINUTES=480

# Admin Credentials
ADMIN_EMAIL=admin@svck.edu.in
ADMIN_PASSWORD=your-strong-admin-password
# Prefer ADMIN_PASSWORD_HASH in production instead of ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# Firebase Admin Service Account
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or provide the full JSON content instead of a path:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Gemini AI API Key (backend only)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Feature flags
TESTING_MODE=false
FACE_DETECTION_MODEL=hog
# FACE_MATCH_TOLERANCE: distance threshold for attendance verification.
# face_recognition default is 0.6. Use 0.55 for good accuracy/security balance.
# Lower = stricter (more false rejections). Higher = looser (possible false accepts).
FACE_MATCH_TOLERANCE=0.55
# FACE_DUPLICATE_TOLERANCE: how close two faces must be to be considered the same person
# during registration duplicate check. Lower = stricter (less likely to block valid new users).
FACE_DUPLICATE_TOLERANCE=0.45
# Minimum photos required from user to register face (5 is sufficient with quality 0.8)
FACE_REGISTER_MIN_IMAGES=5
# Minimum successfully detected face encodings needed (3 from 5 is a reasonable threshold)
FACE_REGISTER_MIN_ENCODINGS=3
FACE_REGISTER_TARGET_ENCODINGS=5

# CORS Allowed Origins (comma-separated, no trailing slashes)
# Development: local IPs
# Production: use * to allow all (mobile apps don't send Origin headers)
ALLOWED_ORIGINS=*

# Campus Geo-fencing
CAMPUS_LATITUDE=14.459705443779649
CAMPUS_LONGITUDE=78.81842145279516
CAMPUS_RADIUS_METERS=100
