rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // SVCK Digital - Firestore Security Rules
    // ==========================================

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user owns this document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==========================================
    // Students Collection
    // ==========================================
    match /students/{studentId} {
      // Students can read their own profile
      allow read: if isOwner(studentId);
      
      // Only backend (admin SDK) can create/update students
      // Client-side writes are blocked
      allow write: if false;
    }

    // ==========================================
    // Face Encodings Collection (Biometric Data)
    // ==========================================
    match /face_encodings/{studentId} {
      // No client-side access - all operations through backend Admin SDK
      allow read, write: if false;
    }

    // ==========================================
    // Attendance Collection
    // ==========================================
    match /attendance/{attendanceId} {
      // Students can read their own attendance
      allow read: if isAuthenticated() && 
        resource.data.student_id == request.auth.uid;
      
      // Only backend (admin SDK) can write attendance
      allow write: if false;
    }

    // ==========================================
    // Default: Deny all other access
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
